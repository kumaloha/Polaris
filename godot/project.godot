; Godot 4.6 — 魔法道具消除 Core 原型（裸 Core，无 Meta）
; 设计依据见 ../docs/04_CORE_消除.md, 05_技术架构.md, 09_算法系统设计.md

config_version=5

[application]

config/name="Magic Match Core Prototype"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

Fx="*res://match3/effect_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1520
window/size/window_width_override=432
window/size/window_height_override=912
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[debug]

gdscript/warnings/unused_parameter=0
