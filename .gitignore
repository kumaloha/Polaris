# OS
.DS_Store

# OMC / 工具本地状态（不入库）
.omc/
.omx/

# Godot 导入缓存 / 临时渲染产物（不入库）
.godot/
godot/_shot*.png

# C++ 构建产物
engine/build/

# 编辑器
.vscode/
.idea/
*.swp

# 大体量美术资源(pieces/characters ~80MB)先不入库；本地有，日后按需 git-lfs。
resources/*.png
resources/*.html
resources/**/*.png
resources/**/*.jpg

# 运行时美术挪到 res://art/(Godot 导入→导出可带)；本地有，体量大暂不入库(同 resources 策略)。manifest(.json)入库。
godot/art/**/*.png
godot/art/**/*.import
!godot/art/gems/**/*.png
!godot/art/vfx/**/*.png
