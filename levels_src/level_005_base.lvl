  "level_design": {
    "id": "level_005",
    "thesis": {
      "key": "open_gate_restores_flow",
      "sentence": "打开晶壳门，水文才恢复。"
    },
    "fantasy": "敲开晶壳闸门，把魔法水流放进下游星尘池。",
    "roles": {
