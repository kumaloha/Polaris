      "friction_zone": "center_gate",
      "payoff_zone": "downstream_pool",
      "operation_space": "upper_and_side_board",
      "supply_logic": "gate_blocks_downstream_flow_but_not_full_row"
    },
    "objective": {
      "world_state_change": "stardust_pool_cleansed_after_gate_opens",
      "player_readable_goal": "先开门，再净化门后的星尘池。"
    },
    "arc": {
      "opening": "中央晶壳门压住下游星尘池。",
      "friction": "直接清下游效率低，必须先破门。",
      "turn": "晶壳门破出缺口，补给穿过门洞。",
      "payoff": "门后星尘被一波连锁净化。"
    },
    "payoff": {
      "signature": "中央晶壳门裂开，宝石瀑布落入下游星尘池。"
    },
    "negative_space": {
      "statement": "门外保留两侧操作空地，不堆第二种障碍。",
      "forbid": [
        "collect",
        "creep_growth",
        "drop_relic",
        "order_color",
        "spawner",
        "timed_core"
      ],
      "preserve": [
        "side_operation_space",
        "readable_gate_path"
      ]
    },
    "four_in_one": {
      "play": "晶壳是主角，星尘是门后的收益。",
      "visual": "晶壳门像横向闸坝压住下方目标区。",
      "readability": "最硬最亮的门就是先处理点。",
      "theme": "晶能工坊封印门被魔法敲开。"
    },
    "solution": {
      "intended_solution": [
        "在门附近制造消除",
        "优先破中央晶壳",
        "门开后让下游连锁净化星尘"
      ],
      "crack_path": [
