    "id": "level_007",
    "thesis": {
      "key": "two_pages_need_two_plans",
      "sentence": "裂开的两页各自补给，左右星尘要分别照顾。"
    },
    "fantasy": "修复被裂缝分成左右两页的魔法书。",
    "roles": {
      "protagonist": {
        "mechanism": "target_mark",
        "as": "split_page_stardust"
      },
      "support": [],
